---
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: 'menu' | 'reservas';
}
const { title, activePage } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="La Mesa — Pedidos y reservas online" />
    <title>{title} — La Mesa</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍽️</text></svg>" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">🍽️ La Mesa</a>
        <nav aria-label="Navegación principal">
          <a href="/" class:list={['nav-link', { active: activePage === 'menu' }]}>Menú</a>
          <a href="/reservas" class:list={['nav-link', { active: activePage === 'reservas' }]}>Reservar mesa</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© 2026 La Mesa &middot; Pedidos y reservas online</p>
      </div>
    </footer>
  </body>
</html>
